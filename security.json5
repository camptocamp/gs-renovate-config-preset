{
  vulnerabilityAlerts: {
    enabled: true,
    labels: ['security'],
  },
  osvVulnerabilityAlerts: true,
  packageRules: [
    /** Immediately update security related packages and pytz */
    {
      groupName: 'security packages',
      matchDepNames: ['cryptography', 'pyOpenSSL', 'pyopenssl', 'certifi', 'pytz'],
      enabled: true,
      schedule: ['before 6am'],
      minimumReleaseAge: '0',
      automerge: true,
    },
    /** Automerge security updates */
    {
      matchUpdateTypes: ['security'],
      schedule: ['before 6am'],
      minimumReleaseAge: '0',
      automerge: true,
    },
    /** Force upgrade for packages with a dependency on a package with a CVE */
    /** Force pytest-asyncio to at least 1.3.0 due to its dependency on a vulnerable pytest version */
    {
      groupName: 'security packages',
      matchDepNames: ['pytest-asyncio'],
      matchCurrentVersion: '<1.3.0',
      allowedVersions: '1.3.0',
      enabled: true,
      schedule: ['before 6am'],
      minimumReleaseAge: '0',
      automerge: true,
    },
  ],
}
