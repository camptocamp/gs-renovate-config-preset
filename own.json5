{
  packageRules: [
    /** Immediately update own maintained packages */
    {
      groupName: 'own packages',
      matchDepNames: ['c2cwsgiutils', 'camptocamp/c2cwsgiutils', 'c2casgiutils', 'helm-common'],
      schedule: 'before 6am',
      minimumReleaseAge: '0',
      automerge: true,
    },
    /** Replace deprecated Prospector repository */
    {
      matchDepNames: ['PyCQA/prospector', 'landscape/prospector'],
      replacementName: 'prospector-dev/prospector',
    },
    /** Don't group CI dependencies */
    {
      matchDepNames: [
        'prospector',
        'prospector-dev/prospector',
        'landscape/prospector',
        'PyCQA/prospector',
        'prospector-profile-duplicated',
        'prospector-profile-utils',
        'c2cciutils',
        'tag-publish',
        'camptocamp/tag-publish',
        'jsonschema-gentypes',
        'camptocamp/jsonschema-gentypes',
        'jsonschema2md',
        'camptocamp/jsonschema2md',
        'gs-renovate-config-preset',
        'camptocamp/gs-renovate-config-preset',
        'sbrunner/hooks',
        'sbrunner/python-version-hook',
      ],
      schedule: 'before 6am',
      minimumReleaseAge: '0',
      automerge: true,
    },
  ],
}
