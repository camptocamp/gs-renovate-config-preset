{
  packageRules: [
    /** Immediately update own maintained packages */
    {
      groupName: 'own packages',
      matchDepNames: ['c2cwsgiutils', 'camptocamp/c2cwsgiutils', 'c2casgiutils', 'helm-common'],
      schedule: 'before 6am',
      minimumReleaseAge: '0',
      automerge: true,
    },
    /**
     * Create a dedicated group for Renovate config preset
     * to always be able to update it easily
     */
    {
      groupName: 'Renovate config preset',
      matchDepNames: ['gs-renovate-config-preset', 'camptocamp/gs-renovate-config-preset'],
      schedule: 'before 6am',
      minimumReleaseAge: '0',
      automerge: true,
    },
    /** Don't group CI dependencies */
    {
      matchDepNames: [
        'prospector',
        'prospector-dev/prospector',
        'landscape/prospector',
        'PyCQA/prospector',
        'prospector-profile-duplicated',
        'prospector-profile-utils',
        'c2cciutils',
        'tag-publish',
        'camptocamp/tag-publish',
        'jsonschema-gentypes',
        'camptocamp/jsonschema-gentypes',
        'jsonschema2md',
        'camptocamp/jsonschema2md',
        'sbrunner/hooks',
        'sbrunner/python-version-hook',
      ],
      schedule: 'before 6am',
      minimumReleaseAge: '0',
      automerge: true,
    },
  ],
}
