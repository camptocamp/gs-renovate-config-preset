{
  packageRules: [
    /** Group and auto merge the patch/minor updates */
    {
      groupName: 'all patch/minor versions',
      matchUpdateTypes: ['patch', 'minor'],
      automerge: true,
    },
    /** Group and auto merge the version pinning */
    {
      groupName: 'Pin dependencies',
      matchUpdateTypes: ['pin', 'pinDigest'],
      automerge: true,
      schedule: ['before 6am'],
    },
  ],
}
