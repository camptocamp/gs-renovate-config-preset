{
  packageRules: [
    /** Group Python dev dependency updates */
    {
      matchDepTypes: ['devDependencies'],
      matchDatasources: ['pypi'],
      groupName: 'CI dependencies',
      automerge: true,
    },
    /** Group and auto merge the CI dependencies */
    {
      matchFileNames: ['.github/**', '.pre-commit-config.yaml', 'ci/**'],
      groupName: 'CI dependencies',
      automerge: true,
    },
    /** Group and auto merge dependencies used to check, build, and publish the project */
    {
      matchDepNames: [
        /* Python */
        'poetry',
        'poetry-.*',
        'prospector',
        'prospector-.*',
        'ruff',
        'pylint',
        'mypy',
        'ty',
        'pyrefly',
        /* CI */
        'c2cciutils',
        'tag-publish',
        /* JavaScript */
        'vite',
        '@vitejs/*',
        'vite-plugin-*',
        'fs-extra',
        'minify',
        'sass-embedded',
        'eslint',
        'eslint-plugin-*',
        'typescript',
        '@typescript-eslint/*',
        'storybook',
        '@storybook/*',
        'chromatic',
        '@chromatic-com/*',
      ],
      groupName: 'CI dependencies',
      automerge: true,
      separateMajorMinor: false,
    },
    /**
     * Override CI dependencies grouping for Renovate config preset
     * This rule must come after the matchFileNames rule to take precedence
     */
    {
      matchDepNames: ['gs-renovate-config-preset', 'camptocamp/gs-renovate-config-preset'],
      groupName: 'Renovate config preset',
    },
  ],
}
